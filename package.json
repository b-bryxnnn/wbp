{
  "name": "wbp-vote-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && npm run copy-static",
    "copy-static": "node -e \"const fs=require('fs');function c(s,d){fs.mkdirSync(d,{recursive:true});fs.readdirSync(s,{withFileTypes:true}).forEach(e=>{const sp=s+'/'+e.name,dp=d+'/'+e.name;e.isDirectory()?c(sp,dp):fs.copyFileSync(sp,dp)})};c('.next/static','.next/standalone/.next/static');console.log('Copied .next/static to standalone')\"",
    "start": "node .next/standalone/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "4.15.0",
    "bcryptjs": "^3.0.3",
    "cookie": "0.6.0",
    "jsonwebtoken": "9.0.2",
    "lucide-react": "^0.577.0",
    "next": "13.4.0",
    "pdfkit": "0.13.0",
    "prisma": "4.15.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-qr-code": "2.0.12",
    "socket.io": "4.7.2",
    "socket.io-client": "4.7.2",
    "tailwindcss": "3.3.0",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie": "0.5.4",
    "@types/jsonwebtoken": "9.0.5",
    "@types/node": "18.19.0",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "autoprefixer": "10.4.16",
    "postcss": "8.4.31",
    "ts-node": "10.9.2",
    "typescript": "5.4.5"
  }
}
